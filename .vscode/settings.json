{
    /* Pixi environment support */
    "terminal.integrated.defaultProfile.osx": "pixi",
    "terminal.integrated.defaultProfile.linux": "pixi",
    "terminal.integrated.defaultProfile.windows": "pixi",
    "terminal.integrated.profiles.osx": {
        "pixi": {
            "path": "zsh",
            "args": ["-c", "export PATH=\"$HOME/.pixi/bin:$PATH\" && pixi shell-hook --shell zsh && exec zsh"]
        }
    },
    "terminal.integrated.profiles.linux": {
        "pixi": {
            "path": "bash",
            "args": ["-c", "export PATH=\"$HOME/.pixi/bin:$PATH\" && pixi shell-hook --shell bash && exec bash"]
        }
    },
    "terminal.integrated.profiles.windows": {
        "pixi": {
            "path": "powershell",
            "args": ["-Command", "$env:PATH = \"$env:USERPROFILE\\.pixi\\bin;$env:PATH\"; pixi shell-hook --shell powershell | Invoke-Expression"]
        }
    },
    /* Pixi extension settings */
    "pixi.path": "${env:HOME}/.pixi/bin/pixi",
    "pixi.defaultEnvironment": "default",
    "pixi.activateEnvironmentInTerminal": true,
    "pixi.detectionMode": "auto",

    /* C/C++ file settings */
    "[c]": {
        "editor.rulers": [120],
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    },
    "[cpp]": {
        "editor.rulers": [120],
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    },
    "C_Cpp.formatting": "disabled", // use clangd
    "C_Cpp.intelliSenseEngine": "disabled", // use clangd
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,

    /* CMake settings */
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.environment": {
        "PATH": "${env:HOME}/.pixi/bin:${env:PATH}"
    },
    "c-cpp-flylint.clang.enable": false,
    "c-cpp-flylint.cppcheck.suppressions": [
        "missingIncludeSystem",
        "unusedFunction",
        "unusedStructMember"
    ],
    "c-cpp-flylint.lizard.enable": false,
    "c-cpp-flylint.flawfinder.enable": false,
    "c-cpp-flylint.flexelint.enable": false,

    /* toml file settings */
    "[toml]": {
        "editor.defaultFormatter": "tombi-toml.tombi",
        "editor.formatOnSave": true
    },

    /* json, jsonc */
    "[json][jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    /* yaml */
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },

    /* markdown */
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
        "editor.formatOnSave": true,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off"
        }
    },
    "markdown-preview-enhanced.breakOnSingleNewLine": false,

    "files.associations": {
        ".clang-format": "yaml",
        ".clang-tidy": "yaml",
        ".clangd": "yaml",
        "dprint.json": "jsonc",
        "settings.json": "jsonc"
    },

    /* ignore, exclude settings */
    "files.exclude": {
        // Python environments
        "**/.venv": true,
        "**/.nox": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
        "**/__pycache__": true,
        "**/*.egg-info": true,
        // C++ build artifacts
        "**/.pixi": true,
        "**/build": true,
        "**/.cache": true,
        "**/*.o": true,
        "**/*.obj": true
    },
    "files.watcherExclude": {
        // Python environments
        "**/.venv": true,
        "**/.nox": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
        "**/__pycache__": true,
        "**/ext": true,
        // C++ build artifacts
        "**/.pixi": true,
        "**/build": true,
        "**/.cache": true,
        "**/*.o": true,
        "**/*.obj": true,
        "**/CMakeFiles": true
    },
    "search.exclude": {
        // Python environments
        "**/.venv": true,
        "**/.nox": true,
        "**/.ruff_cache": true,
        "**/.pytest_cache": true,
        "**/__pycache__": true,
        "**/ext": true,
        // C++ build artifacts
        "**/.pixi": true,
        "**/build": true,
        "**/.cache": true,
        "**/CMakeFiles": true
    }
}
